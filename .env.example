# ═══════════════════════════════════════════════════════════
# ZoneWise.AI Loan Platform — Environment Variables
# Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════════

# ─── Supabase (Required) ───────────────────────────────────
# Get from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key (server-side only — NEVER expose in client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── AI Underwriting (Optional — falls back to algorithmic) ─
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# ─── Smart Router (Optional — enables multi-tier routing) ──
# Get from: https://aistudio.google.com/apikey
GEMINI_API_KEY=AIza-your-key-here

# Get from: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-your-key-here

# ─── Deployment (CI/CD only) ──────────────────────────────
# GitHub PAT with repo + workflow scope
GH_TOKEN=ghp_your-token-here

# Get from: https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_TOKEN=your-cf-token
CLOUDFLARE_ACCOUNT_ID=your-cf-account-id
